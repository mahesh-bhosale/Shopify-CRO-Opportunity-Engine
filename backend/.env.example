# ── Shopify CRO Opportunity Engine — Backend Environment Variables ──

# Google Gemini API key (get one at https://aistudio.google.com/apikey)
# Leave empty or use a placeholder to run in local diagnostic fallback mode.
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model name (gemini-2.0-flash recommended)
GEMINI_MODEL=gemini-2.0-flash

# Maximum number of pages to scrape per store audit
MAX_PAGES_TO_SCRAPE=4

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000
